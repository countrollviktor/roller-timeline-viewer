# Countroll API — Environment Variables
#
# Auth: OAuth2 Authorization Code flow (Keycloak public client).
# No server-side credentials required — users log in via Keycloak redirect.
# The Keycloak client's Valid Redirect URIs and Web Origins must include
# this app's origin (e.g. http://localhost:5173 for local dev, and your
# Azure App Service URL for prod).

VITE_OAUTH_CLIENT_ID=countroll-app-client
VITE_THIRD_PARTY_ID=2

# Optional overrides (defaults shown)
# VITE_OAUTH_TOKEN_URL=https://sso.countroll.com/realms/countroll-realm/protocol/openid-connect/token

# Production server only (read by server.js, not the browser):
# COUNTROLL_API_URL=https://api.countroll.com

# Stats dashboard (server-side only, optional in dev)
# STATS_ALLOWLIST=user1,user2
# APPINSIGHTS_API_KEY=<read-only data-plane key on hannecard-locations-ai-prod>
